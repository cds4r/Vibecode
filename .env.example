# ============ Общие настройки ============
# Порт веб-сервера
PORT=3000
# Публичный адрес сайта (для ссылок в боте, платежей и т.п.)
PUBLIC_URL=http://localhost:3000
# Название бренда (отображается на сайте и в боте)
BRAND_NAME=VibeVPN

# Разрешить «демо-оплату» без реального платёжного провайдера.
# true — на сайте и в боте появляется кнопка мгновенного подтверждения оплаты (для тестов).
# В боевом режиме поставьте false.
ALLOW_MOCK_PAY=true

# Ключ администратора для защищённых эндпоинтов (/api/admin/*). Придумайте свой.
ADMIN_KEY=change-me-admin-key

# Email-аккаунты с доступом в админку (через запятую). Пользователь с таким email,
# войдя в свой аккаунт, автоматически получает доступ к /admin/.
ADMIN_EMAILS=

# ============ Ссылка-подписка (endpoint /sub/:token) ============
# Название подписки, как оно показывается в VPN-клиенте (Profile-Title).
SUB_TITLE=VibeVPN
# Название сервера (подпись каждого конфига), напр. «🇷🇺 Россия».
SUB_SERVER_NAME=🇷🇺 Россия
# Публичный адрес, по которому доступна подписка (обычно адрес сайта с портом).
# Пример: http://your-domain:3000  (по умолчанию берётся PUBLIC_URL)
SUB_PUBLIC_URL=
# Как часто клиент обновляет подписку, часов.
SUB_UPDATE_HOURS=24

# ============ Панель 3x-ui ============
# Если не заполнить PANEL_URL — сервер работает в MOCK-режиме
# (выдаёт демо-конфиги, ничего реально не создаёт). Удобно для разработки.
# Пример: https://panel.example.com:2053  (без завершающего /)
PANEL_URL=
PANEL_USERNAME=
PANEL_PASSWORD=
# API-токен панели (3x-ui → Настройки → «Enable API»/токен). Если задан — используется
# приоритетно (Authorization: Bearer), логин по username/password не требуется.
PANEL_API_TOKEN=
# Не проверять TLS-сертификат панели (self-signed/локальный доступ). По умолчанию true.
PANEL_INSECURE_TLS=true
# ID инбаунда в панели, в который добавляются клиенты (число из списка Inbounds)
PANEL_INBOUND_ID=1
# Хост, который подставляется в ссылки конфигов (обычно домен/ip вашего VPN-сервера).
# Если пусто — берётся из адреса панели.
NODE_HOST=
# Базовый адрес встроенного сервиса подписок 3x-ui, если включён (Subscription).
# Пример: https://panel.example.com:2096/sub
SUB_BASE_URL=

# ============ Telegram-бот ============
# Токен бота от @BotFather. Если пусто — бот не запускается, работает только сайт.
BOT_TOKEN=
# Способ оплаты в боте:
#   stars    — оплата звёздами Telegram (не требует платёжного провайдера)
#   provider — оплата через платёжного провайдера (нужен BOT_PROVIDER_TOKEN)
#   mock     — демо-режим (кнопка мгновенного подтверждения, требует ALLOW_MOCK_PAY=true)
BOT_PAYMENT=stars
# Токен платёжного провайдера от @BotFather (нужен только при BOT_PAYMENT=provider)
BOT_PROVIDER_TOKEN=
# Валюта для provider-оплаты (RUB, USD, EUR ...)
BOT_CURRENCY=RUB
# Telegram ID администраторов через запятую (получают уведомления о покупках)
ADMIN_TELEGRAM_IDS=
