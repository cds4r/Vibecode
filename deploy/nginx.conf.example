# Nginx reverse proxy для VibeVPN.
# Скопируйте в /etc/nginx/sites-available/vibevpn, замените домен,
# включите ссылкой в sites-enabled и получите TLS через certbot.
#
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/vibevpn
#   sudo ln -s /etc/nginx/sites-available/vibevpn /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d vpn.example.com     # добавит блок TLS автоматически

server {
    listen 80;
    listen [::]:80;
    server_name vpn.example.com;   # <-- ЗАМЕНИТЕ на свой домен

    # certbot допишет сюда редирект на HTTPS после выпуска сертификата.

    location / {
        proxy_pass http://127.0.0.1:3000;   # PORT из .env
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 90s;
    }

    client_max_body_size 5m;
}
